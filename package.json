{
  "name": "opspilot",
  "version": "0.1.0",
  "private": true,
  "description": "운영 지식, 런북, Slack 지원 흐름을 위한 권한 인식 RAG 에이전트입니다.",
  "packageManager": "pnpm@10.14.0",
  "scripts": {
    "build": "pnpm -r build",
    "dev:api": "pnpm --filter @opspilot/api dev",
    "dev:web": "pnpm --filter @opspilot/web dev",
    "start:api": "pnpm --filter @opspilot/api start",
    "start:web": "pnpm --filter @opspilot/web start",
    "web:smoke": "pnpm --filter @opspilot/web smoke",
    "ingest": "pnpm --filter @opspilot/api ingest",
    "eval": "pnpm --filter @opspilot/api eval",
    "eval:gate-smoke": "pnpm --filter @opspilot/api eval:gate-smoke",
    "eval:history-smoke": "pnpm --filter @opspilot/api eval:history-smoke",
    "eval:cases-smoke": "pnpm --filter @opspilot/api eval:cases-smoke",
    "checklist:smoke": "pnpm --filter @opspilot/api checklist:smoke",
    "incident-plan:smoke": "pnpm --filter @opspilot/api incident-plan:smoke",
    "github:smoke": "pnpm --filter @opspilot/api github:smoke",
    "indexing:smoke": "pnpm --filter @opspilot/api indexing:smoke",
    "retrieval-profile:smoke": "pnpm --filter @opspilot/api retrieval-profile:smoke",
    "retrieval-robustness:smoke": "pnpm --filter @opspilot/api retrieval-robustness:smoke",
    "retrieval-permission-diff:smoke": "pnpm --filter @opspilot/api retrieval-permission-diff:smoke",
    "index-explain:smoke": "pnpm --filter @opspilot/api index-explain:smoke",
    "index-quality:smoke": "pnpm --filter @opspilot/api index-quality:smoke",
    "index-snapshot:smoke": "pnpm --filter @opspilot/api index-snapshot:smoke",
    "document-impact:smoke": "pnpm --filter @opspilot/api document-impact:smoke",
    "revalidation-queue:smoke": "pnpm --filter @opspilot/api revalidation-queue:smoke",
    "revalidation-run:smoke": "pnpm --filter @opspilot/api revalidation-run:smoke",
    "permission:smoke": "pnpm --filter @opspilot/api permission:smoke",
    "authn:smoke": "pnpm --filter @opspilot/api authn:smoke",
    "redaction:smoke": "pnpm --filter @opspilot/api redaction:smoke",
    "prompt-injection:smoke": "pnpm --filter @opspilot/api prompt-injection:smoke",
    "rate-limit:smoke": "pnpm --filter @opspilot/api rate-limit:smoke",
    "idempotency:smoke": "pnpm --filter @opspilot/api idempotency:smoke",
    "readiness:smoke": "pnpm --filter @opspilot/api readiness:smoke",
    "agreement:smoke": "pnpm --filter @opspilot/api agreement:smoke",
    "queue:smoke": "pnpm --filter @opspilot/api queue:smoke",
    "review:smoke": "pnpm --filter @opspilot/api review:smoke",
    "trace:smoke": "pnpm --filter @opspilot/api trace:smoke",
    "lineage:smoke": "pnpm --filter @opspilot/api lineage:smoke",
    "evidence-bundle:smoke": "pnpm --filter @opspilot/api evidence-bundle:smoke",
    "quality-gate:smoke": "pnpm --filter @opspilot/api quality-gate:smoke",
    "question-audit:smoke": "pnpm --filter @opspilot/api question-audit:smoke",
    "replay:smoke": "pnpm --filter @opspilot/api replay:smoke",
    "portfolio:demo": "pnpm --filter @opspilot/api portfolio:demo",
    "portfolio:report": "pnpm --filter @opspilot/api portfolio:report",
    "portfolio-readiness:smoke": "pnpm --filter @opspilot/api portfolio-readiness:smoke",
    "observability:smoke": "pnpm --filter @opspilot/api observability:smoke",
    "observability:slo-smoke": "pnpm --filter @opspilot/api observability:slo-smoke",
    "error-budget:smoke": "pnpm --filter @opspilot/api error-budget:smoke",
    "action-plan:smoke": "pnpm --filter @opspilot/api action-plan:smoke",
    "audit-ledger:smoke": "pnpm --filter @opspilot/api audit-ledger:smoke",
    "freshness:smoke": "pnpm --filter @opspilot/api freshness:smoke",
    "release-gate:smoke": "pnpm --filter @opspilot/api release-gate:smoke",
    "openapi:smoke": "pnpm --filter @opspilot/api openapi:smoke",
    "slack:simulate": "pnpm --filter @opspilot/api slack:simulate",
    "worker:indexing": "pnpm --filter @opspilot/api worker:indexing",
    "docker:build": "docker build --target web --build-arg NEXT_PUBLIC_API_BASE_URL=http://localhost:3000 -t opspilot-web:local .",
    "docker:prod": "docker compose -f docker-compose.yml -f docker-compose.prod.yml up --build",
    "docker:prod:smoke": "sh scripts/docker-prod-smoke.sh",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@types/node": "^22.10.2",
    "typescript": "^5.7.2"
  }
}
