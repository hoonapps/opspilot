{
  "name": "opspilot",
  "version": "0.1.0",
  "private": true,
  "description": "Permission-aware RAG agent for operational knowledge, runbooks, and Slack support workflows.",
  "packageManager": "pnpm@10.14.0",
  "scripts": {
    "build": "pnpm -r build",
    "dev:api": "pnpm --filter @opspilot/api dev",
    "dev:web": "pnpm --filter @opspilot/web dev",
    "start:api": "pnpm --filter @opspilot/api start",
    "start:web": "pnpm --filter @opspilot/web start",
    "web:smoke": "pnpm --filter @opspilot/web smoke",
    "ingest": "pnpm --filter @opspilot/api ingest",
    "eval": "pnpm --filter @opspilot/api eval",
    "eval:gate-smoke": "pnpm --filter @opspilot/api eval:gate-smoke",
    "eval:history-smoke": "pnpm --filter @opspilot/api eval:history-smoke",
    "checklist:smoke": "pnpm --filter @opspilot/api checklist:smoke",
    "github:smoke": "pnpm --filter @opspilot/api github:smoke",
    "indexing:smoke": "pnpm --filter @opspilot/api indexing:smoke",
    "permission:smoke": "pnpm --filter @opspilot/api permission:smoke",
    "authn:smoke": "pnpm --filter @opspilot/api authn:smoke",
    "redaction:smoke": "pnpm --filter @opspilot/api redaction:smoke",
    "readiness:smoke": "pnpm --filter @opspilot/api readiness:smoke",
    "agreement:smoke": "pnpm --filter @opspilot/api agreement:smoke",
    "queue:smoke": "pnpm --filter @opspilot/api queue:smoke",
    "review:smoke": "pnpm --filter @opspilot/api review:smoke",
    "trace:smoke": "pnpm --filter @opspilot/api trace:smoke",
    "portfolio:demo": "pnpm --filter @opspilot/api portfolio:demo",
    "portfolio:report": "pnpm --filter @opspilot/api portfolio:report",
    "observability:smoke": "pnpm --filter @opspilot/api observability:smoke",
    "observability:slo-smoke": "pnpm --filter @opspilot/api observability:slo-smoke",
    "release-gate:smoke": "pnpm --filter @opspilot/api release-gate:smoke",
    "openapi:smoke": "pnpm --filter @opspilot/api openapi:smoke",
    "slack:simulate": "pnpm --filter @opspilot/api slack:simulate",
    "worker:indexing": "pnpm --filter @opspilot/api worker:indexing",
    "docker:build": "docker build --target web --build-arg NEXT_PUBLIC_API_BASE_URL=http://localhost:3000 -t opspilot-web:local .",
    "docker:prod": "docker compose -f docker-compose.yml -f docker-compose.prod.yml up --build",
    "docker:prod:smoke": "sh scripts/docker-prod-smoke.sh",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@types/node": "^22.10.2",
    "typescript": "^5.7.2"
  }
}
