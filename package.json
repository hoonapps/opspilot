{
  "name": "opspilot",
  "version": "0.1.0",
  "private": true,
  "description": "Permission-aware RAG agent for operational knowledge, runbooks, and Slack support workflows.",
  "packageManager": "pnpm@10.14.0",
  "scripts": {
    "build": "pnpm -r build",
    "dev:api": "pnpm --filter @opspilot/api dev",
    "dev:web": "pnpm --filter @opspilot/web dev",
    "start:api": "pnpm --filter @opspilot/api start",
    "start:web": "pnpm --filter @opspilot/web start",
    "web:smoke": "pnpm --filter @opspilot/web smoke",
    "ingest": "pnpm --filter @opspilot/api ingest",
    "eval": "pnpm --filter @opspilot/api eval",
    "checklist:smoke": "pnpm --filter @opspilot/api checklist:smoke",
    "github:smoke": "pnpm --filter @opspilot/api github:smoke",
    "indexing:smoke": "pnpm --filter @opspilot/api indexing:smoke",
    "review:smoke": "pnpm --filter @opspilot/api review:smoke",
    "slack:simulate": "pnpm --filter @opspilot/api slack:simulate",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@types/node": "^22.10.2",
    "typescript": "^5.7.2"
  }
}
