NODE_ENV=development
PORT=3000
MIKRO_ORM_DEBUG=false

DATABASE_HOST=localhost
DATABASE_PORT=25432
DATABASE_NAME=opspilot
DATABASE_USER=opspilot
DATABASE_PASSWORD=opspilot

REDIS_URL=redis://localhost:26379
INDEXING_WORKER_CONCURRENCY=2

ELASTICSEARCH_URL=http://localhost:29200
ENABLE_ELASTICSEARCH=false

AI_PROVIDER=local
AGENT_ORCHESTRATION=tool_use
AGENT_TOOL_USE_MAX_TURNS=4
EMBEDDING_PROVIDER=transformers
RERANK_EMBEDDING_PROVIDER=transformers
EMBEDDING_DIMENSIONS=64
EMBEDDING_CANDIDATE_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4.1-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIMENSIONS=64
OPENAI_EMBEDDING_FALLBACK_TO_LOCAL=false
TRANSFORMERS_EMBEDDING_MODEL=Xenova/paraphrase-multilingual-MiniLM-L12-v2
RUN_TRANSFORMERS_EMBEDDING_SMOKE=false
RUN_TRANSFORMERS_INDEXING_SMOKE=false
DOCUMENT_AGREEMENT_METHOD=semantic_embedding
RUN_SEMANTIC_AGREEMENT_SMOKE=false
RETRIEVAL_RERANKER=embedding
RUN_SEMANTIC_RERANK_SMOKE=false
ANTHROPIC_API_KEY=
ANTHROPIC_CHAT_MODEL=claude-3-5-haiku-latest

RETRIEVAL_MODE=vector
CONFIDENCE_THRESHOLD=0.3
UNSUPPORTED_ANSWER_CONFIDENCE_THRESHOLD=0.15

OPSPILOT_ACTOR_TOKEN_SECRET=

SLACK_SIGNING_SECRET=
SLACK_BOT_TOKEN=
SLACK_BOT_USER_ID=
SLACK_POST_REPLIES=false
SLACK_DEFAULT_TEAM_SLUGS=payments
SLACK_DEFAULT_ROLES=

SEED_DOCUMENTS_DIR=../../seed/documents
EVAL_SET_PATH=../../seed/eval/questions.json
EVAL_MIN_SOURCE_HIT_RATE=1
EVAL_MIN_TOP_SOURCE_ACCURACY=1
EVAL_MIN_HUMAN_REVIEW_ACCURACY=1
EVAL_MIN_DOCUMENT_AGREEMENT_SCORE=0.8
EVAL_MIN_CITATION_ACCURACY=1

SLO_MIN_DOCUMENT_AGREEMENT=0.8
SLO_MAX_HUMAN_REVIEW_RATE=0.7
SLO_MIN_TOOL_AUDIT_COVERAGE=0.95

RELEASE_MIN_DOCUMENTS=5
RELEASE_MIN_CHUNKS=8
RELEASE_MAX_PENDING_APPROVALS=25
