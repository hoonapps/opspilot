    "revalidation-queue:smoke": "ts-node src/cli/revalidation-queue-smoke.ts",
    "revalidation-run:smoke": "ts-node src/cli/revalidation-run-smoke.ts",
    "permission:smoke": "ts-node src/cli/permission-boundary-smoke.ts",
    "authn:smoke": "ts-node src/cli/authn-smoke.ts",
    "redaction:smoke": "ts-node src/cli/redaction-smoke.ts",
    "prompt-injection:smoke": "ts-node src/cli/prompt-injection-smoke.ts",
    "rate-limit:smoke": "ts-node src/cli/rate-limit-smoke.ts",
    "idempotency:smoke": "ts-node src/cli/idempotency-smoke.ts",
