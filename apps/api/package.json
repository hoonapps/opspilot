{
  "name": "@opspilot/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "nest start --watch",
    "start": "node dist/main.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "jest --passWithNoTests",
    "mikro-orm": "mikro-orm --config src/config/mikro-orm.config.ts",
    "db:migrate": "mikro-orm migration:up --config src/config/mikro-orm.config.ts",
    "db:create": "mikro-orm migration:create --config src/config/mikro-orm.config.ts",
    "ingest": "ts-node src/cli/ingest.ts",
    "eval": "ts-node src/cli/evaluate.ts",
    "eval:gate-smoke": "ts-node src/cli/evaluation-gate-smoke.ts",
    "eval:history-smoke": "ts-node src/cli/evaluation-history-smoke.ts",
    "checklist:smoke": "ts-node src/cli/checklist-smoke.ts",
    "github:smoke": "ts-node src/cli/github-sync-smoke.ts",
    "indexing:smoke": "ts-node src/cli/indexing-smoke.ts",
    "permission:smoke": "ts-node src/cli/permission-boundary-smoke.ts",
    "authn:smoke": "ts-node src/cli/authn-smoke.ts",
    "redaction:smoke": "ts-node src/cli/redaction-smoke.ts",
    "readiness:smoke": "ts-node src/cli/readiness-smoke.ts",
    "agreement:smoke": "ts-node src/cli/answer-agreement-smoke.ts",
    "queue:smoke": "ts-node src/cli/queue-indexing-smoke.ts",
    "review:smoke": "ts-node src/cli/review-smoke.ts",
    "trace:smoke": "ts-node src/cli/answer-trace-smoke.ts",
    "portfolio:demo": "ts-node src/cli/portfolio-demo.ts",
    "portfolio:report": "ts-node src/cli/portfolio-demo.ts --report ../../docs/demo-report.md",
    "observability:smoke": "ts-node src/cli/observability-smoke.ts",
    "observability:slo-smoke": "ts-node src/cli/observability-slo-smoke.ts",
    "release-gate:smoke": "ts-node src/cli/release-gate-smoke.ts",
    "openapi:smoke": "ts-node src/cli/openapi-smoke.ts",
    "slack:simulate": "ts-node src/cli/simulate-slack.ts",
    "worker:indexing": "ts-node src/cli/indexing-worker.ts"
  },
  "dependencies": {
    "@opspilot/ai": "workspace:*",
    "@elastic/elasticsearch": "^8.17.0",
    "@mikro-orm/core": "^6.4.2",
    "@mikro-orm/migrations": "^6.4.2",
    "@mikro-orm/nestjs": "^6.1.1",
    "@mikro-orm/postgresql": "^6.4.2",
    "@nestjs/common": "^10.4.15",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.15",
    "@nestjs/platform-express": "^10.4.15",
    "@nestjs/swagger": "^8.1.0",
    "bullmq": "^5.78.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "dotenv": "^16.4.7",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@mikro-orm/cli": "^6.4.2",
    "@nestjs/cli": "^10.4.8",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "mikro-orm": {
    "useTsNode": true,
    "configPaths": [
      "./src/config/mikro-orm.config.ts"
    ]
  }
}
